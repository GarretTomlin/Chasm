# stdlib2 — tests for new standard library additions

def test_shape() do
  print(fract(3.75))
  print(wrap(110.0, 0.0, 100.0))
  print(snap(17.0, 5.0))
  print(smooth_step(0.0, 1.0, 0.5))
  print(ping_pong(3.5, 2.0))
  print(move_toward(0.0, 10.0, 3.0))
  print(sign(-99.0))
end

def test_easing() do
  print(ease_in(0.5))
  print(ease_out(0.5))
  print(ease_in_out(0.5))
  print(ease_in_cubic(0.5))
  print(ease_out_bounce(1.0))
end

def test_vec2() do
  print(vec2_len(3.0, 4.0))
  print(vec2_dot(1.0, 0.0, 0.0, 1.0))
  print(vec2_dist(0.0, 0.0, 3.0, 4.0))
  print(vec2_norm_x(3.0, 4.0))
  print(vec2_norm_y(3.0, 4.0))
  print(vec2_cross(1.0, 0.0, 0.0, 1.0))
end

def test_bitwise() do
  print(bit_and(255, 15))
  print(bit_or(240, 15))
  print(bit_xor(255, 15))
  print(bit_shl(1, 4))
  print(bit_shr(256, 4))
end

def test_string() do
  print(str_upper("hello"))
  print(str_lower("WORLD"))
  print(str_trim("  hi  "))
  print(str_repeat("ab", 3))
  print(str_slice("chasm", 1, 4))
  print(str_contains("hello world", "world"))
  print(str_starts_with("chasm", "cha"))
  print(str_ends_with("chasm", "asm"))
  print(str_eq("abc", "abc"))
  print(str_eq("abc", "xyz"))
end

def test_conversion() do
  print(to_int(3.9))
  print(to_float(42))
  print(to_bool(0))
  print(to_bool(7))
end

def test_assert() do
  assert(1 == 1)
  assert_eq(2 + 2, 4)
  print(1)
end

def main() do
  test_shape()
  test_easing()
  test_vec2()
  test_bitwise()
  test_string()
  test_conversion()
  test_assert()
end
