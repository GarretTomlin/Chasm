# Bootstrap Chasm compiler — parser (AST from token stream).

defstruct Node do
  tag  :: atom
  a    :: int
  b    :: int
  c    :: int
  name :: string
  line :: int
  col  :: int
end

defstruct ParseResult do
  pos      :: int
  np       :: int
  cp       :: int
  node_idx :: int
end

defstruct TypeAnn do
  name :: string
  pos  :: int
end

