enum Direction { North, South, East, West }

defp describe_dir(d :: int) :: int do
  result :: int = case d do
    when 0 -> 1
    when 1 -> 2
    when 2 -> 3
    when 3 -> 4
    _ -> 0
  end
  return result
end

def main() do
  print(describe_dir(0))
  print(describe_dir(1))
  print(describe_dir(2))
  print(describe_dir(3))
end
