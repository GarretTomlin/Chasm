def test_hex() do
  print(0xFF)
end

def test_for_loop() do
  for i in 0..5 do
    print(i)
  end
end

def test_string_concat() do
  name = "world"
  print(str_concat("hello ", name))
end

def test_array() do
  a :: []int = array_new(3)
  a.push(10)
  a.push(20)
  a.push(30)
  print(a.len)
  print(a.get(0))
  print(a.get(2))
end

def main() do
  test_hex()
  test_for_loop()
  test_string_concat()
  test_array()
end
