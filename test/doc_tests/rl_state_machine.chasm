enum GameState { Menu, Playing, Paused, GameOver }

@gs     :: script = GameState.Menu
@score  :: script = 0
@lives  :: script = 3
@player_x :: script = 400.0
@player_y :: script = 300.0
@speed  :: script = 200.0

defp update_menu(dt :: float) do
  if key_pressed(:enter) do
    @gs = GameState.Playing
    @score = 0
    @lives = 3
  end
end

defp update_game(dt :: float) do
  if key_down(:right) do @player_x = @player_x + @speed * dt end
  if key_down(:left)  do @player_x = @player_x - @speed * dt end
  if key_down(:up)    do @player_y = @player_y - @speed * dt end
  if key_down(:down)  do @player_y = @player_y + @speed * dt end
  @score = @score + 1
  if key_pressed(:escape) do
    @gs = GameState.Paused
  end
end

defp update_pause(dt :: float) do
  if key_pressed(:escape) do
    @gs = GameState.Playing
  end
end

defp update_game_over(dt :: float) do
  if key_pressed(:enter) do
    @gs = GameState.Menu
  end
end

def on_tick(dt :: float) do
  case @gs do
    when GameState.Menu     -> update_menu(dt)
    when GameState.Playing  -> update_game(dt)
    when GameState.Paused   -> update_pause(dt)
    when GameState.GameOver -> update_game_over(dt)
    _                       -> 0
  end
end

def on_draw() do
  clear_background(0x181820ff)
  case @gs do
    when GameState.Menu -> draw_text("Press ENTER to play", 200, 280, 24, 0xffffffff)
    when GameState.Playing -> draw_rectangle(@player_x - 16.0, @player_y - 16.0, 32.0, 32.0, 0x44aaffff)
    when GameState.Paused -> draw_text("PAUSED - ESC to resume", 180, 280, 24, 0xffff00ff)
    when GameState.GameOver -> draw_text("GAME OVER - ENTER to retry", 160, 280, 24, 0xff4444ff)
    _ -> 0
  end
  draw_text("Score: #{@score}", 10, 10, 20, 0xffffffff)
end
