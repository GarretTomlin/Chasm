{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["do", "end"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\b(do|else)\\s*$",
    "decreaseIndentPattern": "^\\s*end\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_?!]*"
}
