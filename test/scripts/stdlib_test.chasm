# stdlib test — exercises built-in library functions

def test_math() do
  print(floor(3.7))
  print(ceil(3.2))
  print(round(3.5))
  print(abs(-9.0))
  print(pow(2.0, 8.0))
  print(lerp(0.0, 100.0, 0.25))
  print(sign(-42.0))
  print(clamp(150.0, 0.0, 100.0))
  print(min(3.0, 7.0))
  print(max(3.0, 7.0))
  print(deg_to_rad(180.0))
end

def test_random() do
  n = rand_int(1, 7)
  print(n > 0)
end

def test_string() do
  s = str_concat("hello, ", "chasm")
  print(str_len(s))
  print(int_to_str(42))
  print(float_to_str(3.14))
end

def test_assert() do
  assert(1 < 2)
  assert(true)
  print(1)
end

def main() do
  test_math()
  test_random()
  test_string()
  test_assert()
end
